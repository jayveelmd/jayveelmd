                    ###Exploring your data
      ##Using data in a library
#Create library first
options validvarname=v7;
ods graphics on;

libname pg1 base "/home/u64546456/EPG1V2/data";

proc import datafile="/home/u64546456/EPG1V2/data/storm.xlsx" 
			dbms=xlsx out=storm_damage replace;
	sheet="Storm_Damage";
run;

#List first 10 rows, can click and drag headings into var, change order of report and validate data
proc print data=pg1.storm_summary (obs=10);
	var  Season Name Basin MaxWindMPH MinPressure StartDate EndDate;
run;

#Calculating summary statistics, variables have to be numeric
proc means data=pg1.storm_summary;
	var MaxWindMPH MinPressure;
run;

#Looking into extreme values with proc univariate
proc univariate data=pg1.storm_summary;
	var MaxWindMPH MinPressure;
run;

#Listing unique values and frequencies. replace var with tables and use variables with character values
proc freq data=pg1.storm_summary;
	tables Basin Type Season;
run; 

      ##Using filters in data
#Single filters
proc print data=pg1.storm_summary;
  >where MaxWindMPH GE 165; #Using GT LT GE LE > < >= <= notation, EQ is = NE (Not equal to) is ~=
	>where Basin in ("SI" "NI"); #Using in column notation to include ORs
  >where where StartDate >= "01jan2010"d; #using the SAS date format in quotations followed by d
run;

#Compound filters
proc print data=pg1.storm_summary;
	>where Type="TS" and Hem_EW="W"; #Both conditions at the same time
  >where MaxWindMPH>156 or MinPressure<920; #One of the expressions need to be true for a row to be included in the outcome. 
  >where MaxWindMPH>156 or 0<MinPressure<920;#When you have missing values, it will be included in the report. To exclude them, you can 0< the variable
  >where Age between 20 and 39;#Numeric values of age 20<=x<=39 -- This includes the lower and upper limit
  >where Type="." or Type=" ";#To find missing values in numbers of characters respectively
  >where Age is missing or Age is not missing or Item is null;#Similar syntax. For either numeric or character missing values. If you deal with null values (E.g. DBMS databases)
  >where ParkName contains "Preserve";#Looks at variable with "Preserve" -- Case sensitive
  >where City like "New%";#Wildcard filter - Looks at values starting with new and any characters. Would include New York, Newport, and New
  >where City like "Sant_ %";#Wildcard filter - Underscore is any character. It would return Santa Clara and Santo Domingo (with the space in between)
run;

#Sample compound filter
proc print data=pg1.storm_summary(obs=50);
	where MinPressure is missing;
	where Type is not missing;
	where 150<MaxWindMPH<155;
	where Basin like "_I";
	where Name like "Z%";
run;

#Macrovarables to replace text string variables. Replaces all &"" with "" before executing the code temporarily. Will not save so must be defined at beginning of program before you reference it. Must use double quotation marks.
%let WindSpeed=156;  ##%let WindSpeed=100;
%let BasinCode=NA;   ##%let BasinCode=SP;
%let Date=01JAN2000; ##%let Date=01JAN2010;

proc print data=pg1.storm_summary;
	where MaxWindMPH>=&WindSpeed and Basin="&BasinCode" and StartDate>="&Date"d;
	var Basin Name StartDate EndDate MaxWindMPH;
run;

proc means data=pg1.storm_summary;
	where MaxWindMPH>=&WindSpeed and Basin="&BasinCode" and StartDate>="&Date"d;
	var MaxWindMPH MinPressure;
run;

