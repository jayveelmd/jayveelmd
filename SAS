      ##Formatting Data Values
#Zw.d format example:
#1350 with the Z8. format applied would be displayed as 00001350
#You can find this information by typing Zw.d in the search field and selecting the first link to Zw.d Format.
#You can also find this information by following these steps:
#Select Programming: SAS 9.4 and Viya 3.5.
#In the Quick Links section and under Syntax, select Actions, Procedures, and Language Elements. 
#Under Language Elements, select Formats. 
#Select the link for Zw.d.

#Formatting date and dollar amounts
proc print data=pg1.storm_damage;
	format Date mmddyy10. Cost dollar16.; #format Date mmddyy8. Cost dollar14.; -- removed the first two digits of the year and limit on the characters after the dollar sign
run;

#Formatting start and end date
proc print data=pg1.storm_summary(obs=20);
	format Lat Lon 4. StartDate EndDate date11.;
run;

#Formatting Start date to month values
proc freq data=pg1.storm_summary order=freq;
	tables StartDate;
	format StartDate monname10.;
run;

    ##Sorting data and removing duplicates
#Sorting data where Basin = NA to find highest MaxWindMPH (note: ascending order by default).
proc sort data=pg1.storm_summary out=storm_sort; #need to give output data a name
     where Basin in("NA" "na");    
     by descending MaxWindMPH;
run;

#Can identify and remove adjacent duplicate values. Only first occurrence is kept in the output table
#Making all rows adjacent, removing all but first row, and placing all duplicates into a different table
proc sort data=pg1.storm_detail out=storm_clean nodupkey dupout=storm_dups; #nodupkey - only the first row will be kept. dupout= duplicates that are removed will be sorted in a different table
	by _all_; #This line makes all duplicate rows adjacent
run;

#To view one storm and the line with minimum pressure
proc sort data=pg1.storm_detail out=min_pressure;
	  where Pressure is not missing and Name is not missing; #removes missing rows
  	by descending Season Basin Name Pressure; #specifying descending order #if you did by Sweason Basin descending Name Pressure, it would do the first two columns sorted in order and the last two sorted descending
run;

proc sort data=min_pressure nodupkey dupout=storm_dups2;
	  by descending Season Basin Name;
run;

#Sorting a table of data with some ascending, some descending
proc sort data=pg1.np_summary out=np_sort;
    by Reg descending DayVisits;
    where Type="NP";
run;

#Park dupes exercise
proc sort data=pg1.np_largeparks out=park_clean nodupkey dupout=park_dup;
		by _all_;
run;

